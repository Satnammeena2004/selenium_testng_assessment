
pipeline {

    agent any

    tools {
        maven 'Maven-3.9'
        jdk   'JDK-21'
    }

    // Inputs you choose before running
    parameters {
        choice(
            name:        'BROWSER',
            choices:     ['chrome', 'firefox', 'edge'],
            description: 'Browser to run tests on'
        )
        choice(
            name:        'SUITE',
            choices:     ['smoke', 'regression'],
            description: 'Which test suite to run?'
        )
    }

    environment {
        TIMESTAMP = sh(
            script: 'date +%Y%m%d_%H%M%S',
            returnStdout: true
        ).trim()
    }

    stages {

        stage('Checkout') {
            steps {
                echo '--- Pulling code from GitHub ---'
                git branch: 'main',
                    url: 'https://github.com/Satnammeena2004/selenium_testng_assessment.git'
                echo 'Code ready'
            }
        }

        stage('Build') {
            steps {
                echo '--- Compiling ---'
                sh 'mvn compile -q'
                echo 'Compile successful'
            }
        }

        stage('Run Tests') {
            steps {
                echo "--- Running ${params.SUITE} tests on ${params.BROWSER} ---"


                sh """
                    mvn test \
                    -Dbrowser=${params.BROWSER} \
                    -Dgroups=${params.SUITE} \
                    -DsuiteXmlFile=src/test/resources/testng.xml
                """
            }

            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'target/surefire-reports/*.xml'

                    publishHTML(target: [
                        allowMissing:          true,
                        alwaysLinkToLastBuild: true,
                        keepAll:               true,
                        reportDir:             'reports',
                        reportFiles:           'TestReport.html',
                        reportName:            'Extent Test Report'
                    ])

                    archiveArtifacts(
                        artifacts:         'screenshots/*.png',
                        allowEmptyArchive: true
                    )
                }
            }
        }
    }

    post {
        success {
            echo """
            ==========================================
              ALL TESTS PASSED
              Suite:   ${params.SUITE}
              Browser: ${params.BROWSER}
              Build:   #${env.BUILD_NUMBER}
            ==========================================
            """
        }
        failure {
            echo """
            ==========================================
              TESTS FAILED
              Suite:   ${params.SUITE}
              Browser: ${params.BROWSER}
              Build:   #${env.BUILD_NUMBER}
              Check:   ${env.BUILD_URL}
            ==========================================
            """
        }
        always {
            echo "Done. Result: ${currentBuild.result}"
        }
    }
}