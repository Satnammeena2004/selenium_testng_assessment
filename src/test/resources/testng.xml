<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SeleniumAssessmentSuite" verbose="1">

    <!-- Register listener — auto fires on every test event -->
    <listeners>
        <listener class-name="qa.listeners.TestListeners"/>
    </listeners>

    <!-- ======== SMOKE SUITE ======== -->
    <!--
        Runs only smoke tests.
        Quick check of critical paths.
        Takes about 2-3 minutes.
    -->
    <test name="SmokeTests">
        <parameter name="browser" value="chrome"/>
                <groups>
                    <run>
                        <include name="smoke"/>
                    </run>
                </groups>
        <classes>
            <class name="qa.tests.LoginTest"/>
            <class name="qa.tests.SearchTest"/>
            <class name="qa.tests.CartTest"/>
        </classes>
    </test>
    <test name="RegressionTests">
        <parameter name="browser" value="chrome"/>
                <groups>
                    <run>
                        <include name="regression"/>
                    </run>
                </groups>
        <classes>
            <class name="qa.tests.LoginTest"/>
            <class name="qa.tests.SearchTest"/>
            <class name="qa.tests.CartTest"/>
        </classes>
    </test>

</suite>